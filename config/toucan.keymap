#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>

#define BASE 0
#define NAV  1
#define SYM  2
#define ADJ  3
#define PAD  4

/ {
    conditional_layers {
        compatible = "zmk,conditional-layers";

        tri_layer {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base {
            display-name = "BASE";
            bindings = <
&kp TAB    &kp B  &kp L  &kp D     &kp C  &kp V      &kp J    &kp Y      &kp O     &kp U     &kp COMMA  &kp BSPC
&kp LCTRL  &kp N  &kp R  &kp T     &kp S  &kp G      &kp P    &kp H      &kp A     &kp E     &kp I      &kp MINUS
&kp LSHFT  &kp X  &kp Q  &kp M     &kp W  &kp Z      &kp K    &kp F      &kp SQT   &kp SEMI  &kp DOT    &kp ESC
                         &kp LGUI  &mo 1  &kp SPACE  &kp RET  &kp SPACE  &kp RALT
            >;
        };

        nav {
            display-name = "NAV";
            bindings = <
&kp TAB     &kp N1          &kp N2        &kp N3        &kp N4        &kp N5        &kp N6    &kp N7    &kp N8    &kp N9     &kp N0  &kp BSPC
&bt BT_CLR  &bt BT_SEL 0    &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &kp LEFT  &kp DOWN  &kp UP    &kp RIGHT  &trans  &trans
&kp LSHFT   &studio_unlock  &trans        &trans        &trans        &trans        &trans    &trans    &trans    &trans     &trans  &trans
                                          &kp LGUI      &trans        &kp SPACE     &kp RET   &trans    &kp RALT
            >;
        };

        sym {
            display-name = "SYM";
            bindings = <
&kp TAB    &kp EXCL  &kp AT  &kp HASH  &kp DLLR  &kp PRCNT  &kp CARET  &kp AMPS   &kp KP_MULTIPLY  &kp LPAR  &kp RPAR  &kp BSPC
&kp LCTRL  &trans    &trans  &trans    &trans    &trans     &kp MINUS  &kp EQUAL  &kp LBKT         &kp RBKT  &kp BSLH  &kp GRAVE
&kp LSHFT  &trans    &trans  &trans    &trans    &trans     &kp UNDER  &kp PLUS   &kp LBRC         &kp RBRC  &kp PIPE  &kp TILDE
                             &kp LGUI  &trans    &kp SPACE  &kp RET    &trans     &kp RALT
            >;
        };

        adj {
            display-name = "ADJ";
            bindings = <
&trans     &trans  &kp F7  &kp F8    &kp F9  &kp F12    &kp C_VOL_DN  &kp C_MUTE  &kp C_VOL_UP  &trans  &trans  &kp BSPC
&kp LCTRL  &trans  &kp F4  &kp F5    &kp F6  &kp F11    &trans        &trans      &trans        &trans  &trans  &trans
&bt LSHFT  &trans  &kp F1  &kp F2    &kp F3  &kp F10    &trans        &trans      &trans        &trans  &trans  &trans
                           &kp LGUI  &mo 1   &kp SPACE  &kp RET       &mo 2       &kp RALT
            >;
        };

        pad {
            display-name = "PAD";
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
                        &mkp LCLK  &mkp MCLK  &mkp RCLK    &trans  &trans  &trans
            >;
        };
    };
};
